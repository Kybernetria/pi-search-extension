{
  "protocolVersion": "0.2.0",
  "nodeId": "pi-search-extension",
  "packageId": "pi-search-extension",
  "version": "0.2.0",
  "purpose": "Minimal private-first web search, local content extraction, and local content cache for Pi agents.",
  "tags": ["pi", "search", "web", "minimal", "privacy"],
  "provides": [
    {
      "name": "web_search",
      "description": "Minimal web search. Uses configured SearXNG endpoint first; optional Brave fallback. No Exa/Perplexity/OpenAI by default.",
      "tags": ["search", "web"],
      "effects": ["network"],
      "inputSchema": { "type": "object", "properties": { "query": { "type": "string" }, "queries": { "type": "array", "items": { "type": "string" } }, "max_results": { "type": "number" }, "provider": { "type": "string", "enum": ["searxng", "brave"] } } },
      "outputSchema": { "type": "object" },
      "execution": { "type": "handler", "handler": "web_search" }
    },
    {
      "name": "fetch_content",
      "description": "Fetch and locally extract readable content from a URL or PDF. Jina fallback is opt-in only. Stores full result in local cache.",
      "tags": ["web", "extract", "cache"],
      "effects": ["network", "filesystem"],
      "inputSchema": { "type": "object", "required": ["url"], "properties": { "url": { "type": "string" }, "quality_threshold": { "type": "number" }, "force_jina": { "type": "boolean" }, "max_chars": { "type": "number" } } },
      "outputSchema": { "type": "object" },
      "execution": { "type": "handler", "handler": "fetch_content" }
    },
    {
      "name": "get_cached_content",
      "description": "Retrieve locally cached content by id or URL with offset/length slicing.",
      "tags": ["cache", "content"],
      "effects": ["filesystem"],
      "inputSchema": { "type": "object", "properties": { "id": { "type": "string" }, "url": { "type": "string" }, "start": { "type": "number" }, "max_chars": { "type": "number" } } },
      "outputSchema": { "type": "object" },
      "execution": { "type": "handler", "handler": "get_cached_content" }
    }
  ]
}
