{
  "name": "pi-search-extension",
  "version": "0.1.0",
  "description": "Minimal private-first Pi extension for web search, local content extraction, and cached content retrieval.",
  "type": "module",
  "main": "./extension.ts",
  "exports": {
    ".": "./extension.ts",
    "./tools": "./src/tools.ts",
    "./protocol/handlers": "./protocol/handlers.ts",
    "./pi.protocol.json": "./pi.protocol.json"
  },
  "keywords": [
    "pi-package",
    "pi",
    "search",
    "minimal",
    "web",
    "pi-protocol"
  ],
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kybernetria/pi-protocol": "file:../../pi-protocol/packages/pi-protocol",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^26.0.1",
    "@types/turndown": "^5.0.6",
    "typebox": "^1.1.34",
    "typescript": "^5.0.0"
  },
  "pi": {
    "extensions": [
      "./extension.ts"
    ]
  },
  "files": [
    "index.ts",
    "extension.ts",
    "src",
    "protocol",
    "archive",
    "pi.protocol.json",
    "README.md"
  ]
}
